{
  "absolute": true,
  "ignore": [
    "*********** GLOBAL ***********",

    ".github/**",
    ".jscpd/**",
    ".snappy/**",
    "**/dist/**",
    "**/build/**",
    "**/*.json",
    "**/*.html",
    "**/*.xml",
    "**/*.patch",
    "**/*.module.scss.d.ts",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/node_modules/**",
    "**/packages/*/src/generated/**",

    "*********** FILES ***********",

    "packages/ai-stream/src/themes/chat/Theme.ts",
    "packages/ai-stream/src/themes/reasoning/Theme.ts",
    "packages/app/src/pages/auth/SignIn.view.tsx",
    "packages/app/src/pages/auth/SignUp.view.tsx",
    "packages/app/src/pages/settings/profile/SettingsProfilePassword.view.tsx",
    "packages/app/src/pages/settings/profile/SettingsProfileTopUp.view.tsx",
    "packages/app/src/pages/settings/Settings.view.tsx",
    "packages/browser/src/speech/SpeechRecognizerDesktop.ts",
    "packages/coder-store/src/core/Workspace.ts",
    "packages/coder-store/src/tools/DeleteFileTool.ts",
    "packages/coder-store/src/tools/ReadFileTool.ts",
    "packages/coder-store/src/tools/WriteFileTool.ts",
    "packages/app/src/catalog/items/greeting-message/Agent.ts",
    "packages/app/src/catalog/items/meeting-recap/Agent.ts",
    "packages/app/src/catalog/items/podcast-notes/Agent.ts",
    "packages/app/src/catalog/items/text-improve/Agent.ts",
    "packages/app/src/catalog/items/profile-photo/Agent.ts",
    "packages/app/src/catalog/items/flow-diagram/Agent.ts",
    "packages/app/src/catalog/items/app-icon/Agent.ts",
    "packages/app/src/catalog/items/interior/Agent.ts",
    "packages/app/src/catalog/items/logo-concept/Agent.ts",
    "packages/app/src/catalog/items/postcard/Agent.ts",
    "packages/theme/src/styles/theme-dark.scss",
    "packages/theme/src/styles/theme-light.scss"
  ],
  "ignorePattern": ["import.*from.*"],
  "noGitignore": false,
  "mode": "strict",
  "output": ".jscpd",
  "path": ["."],
  "reporters": ["console", "html"],
  "threshold": 0
}
