{
  "absolute": true,
  "ignore": [
    ".github",
    ".jscpd",
    ".snappy",
    "**/dist/**",
    "**/build/**",
    "**/*.{json,html,xml,module.scss.d.ts}",
    "**/*.test.{ts,tsx}",
    "**/node_modules",
    "**/packages/*/src/generated"
  ],
  "ignorePattern": ["import.*from.*"],
  "gitignore": true,
  "mode": "strict",
  "output": ".jscpd",
  "reporters": ["console", "html"],
  "threshold": 0
}
