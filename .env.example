# Database (used to build the connection string)
DB_USER=snappy
DB_PASSWORD=your_password_here
DB_NAME=snappy_dev
DB_HOST=localhost
DB_PORT=5432

# Cabinet auth (≥32 random chars in production)
JWT_SECRET=your_jwt_secret_min_32_chars_for_dev

# Admin panel (/admin), required in production
ADMIN_USERNAME=
ADMIN_PASSWORD=

# AI: AI Tunnel API key (OpenAI-style), required.
AI_TUNNEL_API_KEY=

# YooKassa keys, required.
YOOKASSA_SECRET_KEY=
YOOKASSA_SHOP_ID=

# SMTP (VK WorkSpace), required in production
SMTP_USER=noreply@snappy-ai.ru
SMTP_PASSWORD=
