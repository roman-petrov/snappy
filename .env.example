# Database (used to build the connection string)
DB_USER=snappy
DB_PASSWORD=your_password_here
DB_NAME=snappy_dev
DB_HOST=localhost
DB_PORT=5432

# Cabinet auth (≥32 random chars in production)
JWT_SECRET=your_jwt_secret_min_32_chars_for_dev

# AI: ProxyAPI-compatible API key (OpenAI-style). Required for /api/llm/*; empty → models unavailable.
SNAPPY_PROXYAPI_KEY=

# YooKassa (optional, payments)
YOOKASSA_SECRET_KEY=
YOOKASSA_SHOP_ID=
